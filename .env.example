DATABASE_URL="postgresql://postgres:postgres@localhost:5432/market_analyzer?schema=public"
DATABASE_URL_TEST="postgresql://postgres:postgres@localhost:5433/market_analyzer_test?schema=public"

# Massive.com (formerly Polygon.io) API key for market data (optional; leave unset to skip auto-pull of key levels)
POLYGON_API_KEY="your_key_here"
# Futures contract ticker for key levels (e.g. ESH25 for ES March 2025). Default: ES
# POLYGON_ES_TICKER="ESH25"
