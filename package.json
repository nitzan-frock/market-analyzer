{
	"name": "market-analyzer",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "npm run db:migrate && vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "husky && (svelte-kit sync || true)",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "eslint .",
		"format": "prettier --write .",
		"format:check": "prettier --check .",
		"test": "vitest run && playwright test",
		"test:unit": "vitest",
		"test:unit:run": "vitest run",
		"test:e2e": "playwright test",
		"docker:up": "docker compose up -d",
		"docker:down": "docker compose down",
		"docker:nuke-test": "docker compose down db-test -v && docker compose up db-test -d",
		"db:migrate": "prisma migrate dev",
		"db:seed": "npx tsx prisma/seed.ts",
		"db:reset": "prisma migrate reset",
		"db:test:migrate": "npx tsx scripts/db-test-run.ts prisma migrate dev",
		"db:test:seed": "npx tsx prisma/seed.ts --test",
		"db:test:reset": "npx tsx scripts/db-test-run.ts prisma migrate reset"
	},
	"devDependencies": {
		"@commitlint/cli": "^20.4.4",
		"@commitlint/config-conventional": "^20.4.4",
		"@eslint/js": "^10.0.1",
		"@playwright/test": "^1.58.2",
		"@sveltejs/adapter-auto": "^7.0.0",
		"@sveltejs/kit": "^2.50.2",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@tailwindcss/vite": "^4.2.1",
		"@testing-library/svelte": "^5.3.1",
		"@types/eslint__js": "^8.42.3",
		"dotenv": "^17.3.1",
		"eslint": "^10.0.3",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.15.2",
		"globals": "^17.4.0",
		"husky": "^9.1.7",
		"jsdom": "^28.1.0",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.5.1",
		"prisma": "^7.5.0",
		"svelte": "^5.51.0",
		"svelte-check": "^4.4.2",
		"tailwindcss": "^4.2.1",
		"tsx": "^4.21.0",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.57.0",
		"vite": "^7.3.1",
		"vitest": "^4.1.0"
	},
	"dependencies": {
		"@prisma/adapter-pg": "^7.5.0",
		"@prisma/client": "^7.5.0",
		"daisyui": "^5.5.19"
	}
}
